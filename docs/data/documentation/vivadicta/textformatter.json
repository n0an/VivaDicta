{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter\/init()"],"anchor":"Initializers","generated":true},{"title":"Type Methods","identifiers":["doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter\/format(_:)"],"anchor":"Type-Methods","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/vivadicta\/textformatter"]}],"identifier":{"url":"doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter","interfaceLanguage":"swift"},"metadata":{"title":"TextFormatter","externalID":"s:9VivaDicta13TextFormatterV","navigatorTitle":[{"kind":"identifier","text":"TextFormatter"}],"roleHeading":"Structure","symbolKind":"struct","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextFormatter","kind":"identifier"}],"modules":[{"name":"VivaDicta"}]},"abstract":[{"type":"text","text":"Formats transcription text into readable paragraphs."}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/com.antonnovoselov.VivaDicta\/s15BitwiseCopyableP","doc:\/\/com.antonnovoselov.VivaDicta\/s8SendableP"]}],"hierarchy":{"paths":[["doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextFormatter","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Algorithm Overview","anchor":"Algorithm-Overview"},{"type":"paragraph","inlineContent":[{"text":"The formatter splits continuous transcription text into paragraphs (chunks) separated by double newlines.","type":"text"},{"text":" ","type":"text"},{"text":"This improves readability for long transcriptions that would otherwise be a wall of text.","type":"text"}]},{"type":"heading","level":2,"text":"Chunking Strategy","anchor":"Chunking-Strategy"},{"type":"paragraph","inlineContent":[{"text":"Each chunk (paragraph) is built by accumulating sentences until one of these conditions is met:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Word count target reached","type":"text"}],"type":"strong"},{"text":": Once a chunk contains ~50 words, it’s considered complete.","type":"text"},{"text":" ","type":"text"},{"text":"This creates paragraphs of roughly equal visual weight.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Sentence limit exceeded","type":"text"}],"type":"strong"},{"text":": If a chunk would contain more than 4 “significant” sentences","type":"text"},{"text":" ","type":"text"},{"text":"(sentences with 4+ words), it’s trimmed to prevent overly long paragraphs.","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Key Concepts","anchor":"Key-Concepts"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Significant sentence","type":"text"}],"type":"strong"},{"text":": A sentence with 4 or more words. Short utterances like “Yes.”, “OK.”,","type":"text"},{"text":" ","type":"text"},{"text":"or “I see.” don’t count toward the sentence limit, allowing natural conversation flow.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Chunk trimming","type":"text"}],"type":"strong"},{"text":": When too many significant sentences accumulate before reaching the word target,","type":"text"},{"text":" ","type":"text"},{"text":"the chunk is cut at the 4th significant sentence to maintain paragraph balance.","type":"text"}]}]}]},{"type":"heading","level":2,"text":"Example","anchor":"Example"},{"type":"paragraph","inlineContent":[{"text":"Input: “Hello. Yes. This is a longer sentence about something important. Another detailed point here.","type":"text"},{"text":" ","type":"text"},{"text":"I agree. The third major idea in this discussion. And finally the fourth significant statement.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Output (chunked):","type":"text"}]},{"type":"codeListing","syntax":null,"code":["Hello. Yes. This is a longer sentence about something important. Another detailed point here.","","I agree. The third major idea in this discussion. And finally the fourth significant statement."]},{"type":"paragraph","inlineContent":[{"text":"Note: “Hello.”, “Yes.”, and “I agree.” don’t count as significant sentences.","type":"text"}]}]}],"references":{"doc://com.antonnovoselov.VivaDicta/documentation/VivaDicta/TextFormatter":{"navigatorTitle":[{"kind":"identifier","text":"TextFormatter"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter","url":"\/documentation\/vivadicta\/textformatter","title":"TextFormatter","type":"topic","abstract":[{"text":"Formats transcription text into readable paragraphs.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TextFormatter"}]},"doc://com.antonnovoselov.VivaDicta/s15BitwiseCopyableP":{"title":"Swift.BitwiseCopyable","type":"unresolvable","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/s15BitwiseCopyableP"},"doc://com.antonnovoselov.VivaDicta/documentation/VivaDicta/TextFormatter/format(_:)":{"role":"symbol","kind":"symbol","url":"\/documentation\/vivadicta\/textformatter\/format(_:)","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter\/format(_:)","title":"format(_:)","type":"topic","abstract":[{"text":"Formats text into readable paragraphs separated by double newlines.","type":"text"}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"format"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}]},"doc://com.antonnovoselov.VivaDicta/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/s8SendableP"},"doc://com.antonnovoselov.VivaDicta/documentation/VivaDicta":{"type":"topic","kind":"symbol","title":"VivaDicta","role":"collection","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta","abstract":[{"type":"text","text":"Dictate Anywhere You Type"}],"url":"\/documentation\/vivadicta"},"doc://com.antonnovoselov.VivaDicta/documentation/VivaDicta/TextFormatter/init()":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/com.antonnovoselov.VivaDicta\/documentation\/VivaDicta\/TextFormatter\/init()","url":"\/documentation\/vivadicta\/textformatter\/init()","title":"init()","type":"topic","abstract":[],"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"()"}]}}}