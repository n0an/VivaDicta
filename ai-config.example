# AI Provider Configuration
# Choose either 'openai' or 'anthropic'
LLM_PROVIDER=openai

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Specify OpenAI model (defaults to gpt-4o)
# LLM_MODEL=gpt-4o

# Anthropic Configuration (if using Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: Specify Anthropic model (defaults to claude-3-5-sonnet-20241022)
# LLM_MODEL=claude-3-5-sonnet-20241022

# GitHub Configuration (automatically set in GitHub Actions)
# GITHUB_TOKEN=automatically_provided_in_actions
# GITHUB_REPOSITORY=automatically_provided_in_actions
